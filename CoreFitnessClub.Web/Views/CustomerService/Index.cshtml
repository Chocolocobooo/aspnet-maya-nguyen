@model CoreFitnessClub.Application.DTOs.ContactDto
@{ ViewData["Title"] = "Customer Service"; }

@{
    var faqs = new List<(string Question, string Answer, bool IsOpen)>
    {
        ("Q1. Do I need prior gym experience to Join CoreFitness?",
         "No, CoreFitness is designed for all fitness levels. Our trainers guide beginners with proper technique.\n\n• Every new member receives a personalised introduction to equipment\n• Workouts are designed to grow with you.",
         true),
        ("Q2. What facilities are included with the membership?", "Our facilities include state-of-the-art gym equipment, group fitness studios, locker rooms, and more.", false),
        ("Q3. Can I try the gym before taking a membership?", "Yes! We offer a 30-day free trial so you can experience CoreFitness before committing.", false),
        ("Q4. Are there group workout programs available?", "Absolutely. We offer HIIT, yoga, cycling, boxing, and more — all included in your membership.", false),
        ("Q5. Is nutrition guidance included in the plans?", "Premium members receive personalised nutrition guidance from our certified nutritionists.", false),
    };
}

<div class="page-title-section"><h1>Customer Service</h1></div>

<div class="cs-page">
    @await Html.PartialAsync("Partials/_Alerts")

    <div class="cs-contact-grid">
        <!-- Image with contact badges -->
        <div class="cs-image">
            <img src="~/images/woman-in-gym.jpg" alt="Customer service" />
            <div class="cs-image-badges">
                <div class="cs-badge">
                    <span class="cs-badge-icon">📞</span>
                    <div>
                        <div style="font-size:0.65rem;color:var(--grey-400);">Phone Number</div>
                        <div>+46) 8 410 521 00</div>
                    </div>
                </div>
                <div class="cs-badge">
                    <span class="cs-badge-icon">✉️</span>
                    <div>
                        <div style="font-size:0.65rem;color:var(--grey-400);">Email Address</div>
                        <div>info@corefitness.se</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Contact Form -->
        <div class="contact-form-card">
            <h2>Contact Us Today</h2>
            <p>Ready to begin your fitness journey? Let our expert trainers guide you.</p>

            <form asp-action="Index" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-error"></div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="FirstName">First Name <span class="req">*</span></label>
                        <input asp-for="FirstName" placeholder="Enter First Name" />
                        <span asp-validation-for="FirstName" class="validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="LastName">Last Name <span class="req">*</span></label>
                        <input asp-for="LastName" placeholder="Enter Last Name" />
                        <span asp-validation-for="LastName" class="validation-error"></span>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Email">Email Address <span class="req">*</span></label>
                        <input asp-for="Email" type="email" placeholder="Enter Email Address" />
                        <span asp-validation-for="Email" class="validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Phone">Phone Number</label>
                        <input asp-for="Phone" placeholder="Enter Phone Number" />
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="Message">Message <span class="req">*</span></label>
                    <textarea asp-for="Message" placeholder="Message"></textarea>
                    <span asp-validation-for="Message" class="validation-error"></span>
                </div>
                <button type="submit" class="btn-submit">
                    Submit Message <span class="btn-submit-arrow">›</span>
                </button>
            </form>
        </div>
    </div>

    <!-- FAQ -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start;margin-top:2rem;">
        <div style="border-radius:var(--radius-xl);overflow:hidden;">
            <img src="~/images/man-lifting.jpg" alt="Training" style="width:100%;height:100%;object-fit:cover;" />
        </div>
        <div>
            <div class="faq-badge">✦ Frequently Asked Questions</div>
            <h2 style="font-size:1.7rem;font-weight:800;color:#111;line-height:1.2;margin-bottom:1.5rem;">
                Common questions about<br />gym and training
            </h2>
            @await Html.PartialAsync("Partials/_FaqSection", faqs)
        </div>
    </div>
</div>
