@model List<(string Question, string Answer, bool IsOpen)>

<div class="faq-list">
    @foreach (var (question, answer, isOpen) in Model)
    {
        <div class="faq-item @(isOpen ? "open" : "")">
            <button class="faq-question" onclick="toggleFaq(this)">
                @question
                <span class="faq-icon">@(isOpen ? "−" : "+")</span>
            </button>
            <div class="faq-answer">@Html.Raw(answer.Replace("\n", "<br/>"))</div>
        </div>
    }
</div>

@section Scripts {
<script>
function toggleFaq(btn) {
    const item = btn.closest('.faq-item');
    const isOpen = item.classList.toggle('open');
    btn.querySelector('.faq-icon').textContent = isOpen ? '−' : '+';
}
</script>
}
