@{ ViewData["Title"] = "Page Not Found"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="notfound-page">
    <div class="notfound-404">
        <span class="num">4</span>
        <img class="notfound-img" src="~/images/404-error-img 1.png" alt="404" />
        <span class="num">4</span>
    </div>
    <h2>Oops! page not found</h2>
    <p>The page you are looking for does not exist.</p>
    <a asp-controller="Home" asp-action="Index" class="btn-back-home">Back to Homepage ›</a>
</div>
