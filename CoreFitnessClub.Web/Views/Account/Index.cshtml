@model CoreFitnessClub.Application.DTOs.UpdateProfileDto
@{ ViewData["Title"] = "My Account"; }

<div class="account-page">
    <h1>My Account</h1>
    @await Html.PartialAsync("Partials/_Alerts")

    <div class="account-grid">
        <!-- Sidebar -->
        <div class="account-sidebar">
            <div class="account-avatar">
                <img src="~/images/about-me.jpg" alt="Profile" />
            </div>
            <div class="account-menu">
                <div class="account-menu-label">Menu Options</div>
                <div class="account-menu-item active">About Me <span class="account-menu-arrow">›</span></div>
                <div class="account-menu-separator"></div>
                <div class="account-menu-item">My Membership <span class="account-menu-arrow">›</span></div>
                <div class="account-menu-separator"></div>
                <div class="account-menu-item">My Bookings <span class="account-menu-arrow">›</span></div>
                <div class="account-menu-separator"></div>
                <form asp-action="Logout" asp-controller="Account" method="post" style="margin:0;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="account-menu-item" style="width:100%;">Sign Out <span class="account-menu-arrow">›</span></button>
                </form>
                <div class="account-menu-separator"></div>
                <!-- Delete Account -->
                <form asp-action="DeleteAccount" asp-controller="Account" method="post"
                      onsubmit="return confirm('Are you sure? This will permanently delete your account and all personal data.');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="account-menu-item danger" style="width:100%;text-align:left;">
                        Remove Account
                    </button>
                </form>
            </div>
        </div>

        <!-- Main -->
        <div class="account-main">

            <!-- Profile Form -->
            <div class="account-card">
                <h2>About Me</h2>
                <form asp-action="Index" method="post">
                    @Html.AntiForgeryToken()
                    <div class="account-input-group">
                        <label asp-for="FirstName">First Name</label>
                        <input asp-for="FirstName" placeholder="Enter First Name" />
                        <span asp-validation-for="FirstName" class="validation-error"></span>
                    </div>
                    <div class="account-input-group">
                        <label asp-for="LastName">Last Name</label>
                        <input asp-for="LastName" placeholder="Enter Last Name" />
                        <span asp-validation-for="LastName" class="validation-error"></span>
                    </div>
                    <div class="account-input-group">
                        <label asp-for="PhoneNumber">Phone Number</label>
                        <input asp-for="PhoneNumber" placeholder="Enter Phone Number" />
                        <span asp-validation-for="PhoneNumber" class="validation-error"></span>
                    </div>
                    <button type="submit" class="btn-save">Save ›</button>
                </form>
            </div>

            <!-- Current Membership -->
            @if (ViewBag.CurrentPlan is CoreFitnessClub.Application.DTOs.MembershipPlanDto plan)
            {
                <div class="account-card">
                    <h3>My Membership</h3>
                    <div style="display:flex;align-items:center;gap:1rem;">
                        <div class="plan-icon">🏋️</div>
                        <div>
                            <div style="font-weight:700;">@plan.Name</div>
                            <div style="font-size:0.82rem;color:var(--grey-400);">@plan.Price.ToString("F2") / month</div>
                        </div>
                    </div>
                </div>
            }

            <!-- Bookings -->
            @if (ViewBag.Bookings is IEnumerable<CoreFitnessClub.Application.DTOs.BookingDto> bookings && bookings.Any())
            {
                <div class="account-card">
                    <h3>My Bookings</h3>
                    <table style="width:100%;border-collapse:collapse;font-size:0.85rem;">
                        <thead>
                            <tr style="border-bottom:2px solid #eee;text-align:left;">
                                <th style="padding:0.5rem;">Class</th>
                                <th style="padding:0.5rem;">Date & Time</th>
                                <th style="padding:0.5rem;">Status</th>
                                <th style="padding:0.5rem;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var booking in bookings)
                            {
                                <tr style="border-bottom:1px solid #f0f0f0;">
                                    <td style="padding:0.6rem 0.5rem;">@booking.ClassName</td>
                                    <td style="padding:0.6rem 0.5rem;">@booking.ClassDateTime.ToString("MMM dd, yyyy HH:mm")</td>
                                    <td style="padding:0.6rem 0.5rem;">
                                        <span style="background:var(--accent-dim);color:#7a9010;padding:0.2rem 0.6rem;border-radius:100px;font-size:0.75rem;font-weight:600;">
                                            @booking.Status
                                        </span>
                                    </td>
                                    <td style="padding:0.6rem 0.5rem;">
                                        @if (booking.Status == "Confirmed")
                                        {
                                            <form asp-action="CancelBooking" asp-controller="Account" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="bookingId" value="@booking.Id" />
                                                <button type="submit" style="background:none;border:none;color:var(--red);font-size:0.78rem;cursor:pointer;">Cancel</button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
